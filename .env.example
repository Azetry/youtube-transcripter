# Required
OPENAI_API_KEY=your_openai_api_key_here

# Optional — A host backup-service delegation
# BACKUP_SERVICE_URL=http://<backup-host>:8000
# BACKUP_SERVICE_TOKEN=replace_with_shared_secret

# Optional — role marker (e.g. backup deployment)
# SERVICE_ROLE=backup

# Optional — authenticated YouTube extraction
# YT_DLP_COOKIES_FILE=/absolute/path/to/cookies.txt
# YT_DLP_COOKIES_FROM_BROWSER=chrome
# YT_DLP_BROWSER_PROFILE=Default
# YT_DLP_BROWSER_CONTAINER=

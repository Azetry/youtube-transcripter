# =============================================================================
# Required
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# Optional — Speaker attribution (pyannote / multi-speaker diarization)
# =============================================================================
# Only needed when using strategy pyannote_v1 (see README).
# Install extras first, e.g.:
#   pip install -r requirements.txt -r requirements-speaker-cpu.txt
# Use a Hugging Face *read* token; you must accept each gated model's terms on
# huggingface.co (e.g. pyannote/speaker-diarization-3.1 and dependencies such as
# pyannote/speaker-diarization-community-1) before downloads succeed.
# PYANNOTE_AUTH_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Optional: huggingface_hub also honors HF_TOKEN if you prefer one name for tools.
# HF_TOKEN=

# =============================================================================
# Optional — Docker backend build: speaker stack (see README "Docker speaker profiles")
# =============================================================================
# When building the backend image: none (default) | cpu | gpu
# Also passed as a runtime env var so the health endpoint can reflect it.
# SPEAKER_PROFILE=none

# =============================================================================
# Optional — Docker GPU runtime (see docker-compose.gpu.yml)
# =============================================================================
# For GPU speaker diarization in Docker, build with SPEAKER_PROFILE=gpu then:
#   docker compose -f docker-compose.yml -f docker-compose.gpu.yml up -d
# Requires NVIDIA Container Toolkit on the host.

# =============================================================================
# Optional — role marker (reflected in /api/health)
# =============================================================================
# SERVICE_ROLE=backup

# =============================================================================
# Optional — authenticated YouTube extraction (yt-dlp)
# =============================================================================
# YT_DLP_COOKIES_FILE=/absolute/path/to/cookies.txt
# YT_DLP_COOKIES_FROM_BROWSER=chrome
# YT_DLP_BROWSER_PROFILE=Default
# YT_DLP_BROWSER_CONTAINER=
